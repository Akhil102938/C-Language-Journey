#include<stdio.h>
int main()
{
    int i,k,count=0,n;
    printf("Enter the size of array:-");
    scanf("%d",&n);
    int a[n];
    printf("Enter array elements:-");
    for(i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    printf("Enter the k value:-");
    scanf("%d",&k);
    for(i=0;i<n;i++)
    {
        if(a[i]>k)
        {
            count++;
        }
    }
    printf("Number of elements Greater then k:- %d",count);
    return 0;
}
