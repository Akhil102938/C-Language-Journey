#include<stdio.h>

int main()
{
    char a[30];
    int count = 0, i = 0;

    printf("Enter your Name: ");
    scanf("%s", a);

    while(a[i] != '\0')
    {
        if(a[i] == 'a' ||
           a[i] == 'e' ||
           a[i] == 'i' ||
           a[i] == 'o' ||
           a[i] == 'u')
        {
            count++;
        }

        i++;
    }

    printf("Vowels = %d", count);

    return 0;
}
